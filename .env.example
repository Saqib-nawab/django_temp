# Copy to .env (or export in your shell) and adjust for your environment.

# Required in production — generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

# "true" for local development, "false" in production
DJANGO_DEBUG=true

# Comma-separated hostnames
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins, needed behind HTTPS proxies, e.g. https://myblog.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Leave unset to use SQLite locally; point at Postgres in production:
# DATABASE_URL=postgres://blog:blog@localhost:5432/blog
